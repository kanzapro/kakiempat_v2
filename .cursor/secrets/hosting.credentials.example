# Salin ke hosting.credentials dan isi nilai asli (file .credentials di-gitignore)

[cpanel]
url=https://kakiempat.com:2083
username=CPANEL_USER
password=CPANEL_PASSWORD
api_token=CPANEL_API_TOKEN
primary_domain=kakiempat.com
shared_ip=178.83.188.195
home_directory=/home/kakiempa
git_repo_path=/home/kakiempa/repo_kakiempat

[mysql_v2]
host=localhost
database=kakiempa_v2
user=kakiempa_v2_user
password=MYSQL_V2_PASSWORD

[api_deploy]
docroot=/home/kakiempa/api.kakiempat.com
health_url=https://www.api.kakiempat.com/index.php
migrate_url=https://www.api.kakiempat.com/apply_v2_migration.php
migrate_secret=MIGRATE_SECRET

[dns]
; Semua A record → shared_ip kecuali www (CNAME ke apex).
; Skrip audit/perbaikan: scripts/fix_dns_v2.ps1
apex_a=kakiempat.com
www_cname=www -> kakiempat.com
web_a=owner,sitter,admin,staging,api,ftp
web_a_www=www.owner,www.sitter,www.admin,www.staging,www.api

[ssl]
; Wildcard *.kakiempat.com + apex — cPanel: SSL/TLS -> Manage SSL / AutoSSL
; Setelah aktif, jalankan: scripts/verify_ssl_v2.ps1
; Web deploy menyertakan hosting/web_shared/.htaccess (HTTPS redirect + HSTS)
wildcard=*.kakiempat.com
apex=kakiempat.com

[subdomains]
; api_www = alias www dari api (docroot sama)
; www     = landing & marketing
; owner   = dashboard pemilik hewan
; sitter  = dashboard pengasuh
; admin   = panel operator
; staging = uji coba (DB/branch terpisah)
; api     = REST backend (PHP docroot, bukan Flutter)
api=api.kakiempat.com
api_www=www.api.kakiempat.com
admin=admin.kakiempat.com
staging=staging.kakiempat.com
owner=owner.kakiempat.com
sitter=sitter.kakiempat.com
www=www.kakiempat.com
