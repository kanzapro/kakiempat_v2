# Kaki Empat v2 — Flutter web (www, owner, sitter, admin, staging)
# Deploy: salin ke docroot setiap subdomain bersama build/web/

Options -Indexes -MultiViews

<IfModule mod_rewrite.c>
RewriteEngine On

# Paksa HTTPS (butuh sertifikat valid / wildcard *.kakiempat.com di cPanel)
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# SPA — semua rute ke index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_headers.c>
Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

<FilesMatch "\.(env|secret|key|credentials|log|sql)$">
Require all denied
</FilesMatch>
